---
import Layout from '../../layouts/Layout.astro';
import MetricCard from '../../components/MetricCard.astro';
import SwimPrognosis from '../../components/SwimPrognosis.astro';
import waterData from '../../../data/data/waterData.json';
import airData from '../../../data/data/airData.json';
import levelData from '../../../data/data/levelData.json';
import qualityData from '../../../data/data/qualityData.json';
import en from '../../locales/en.json';

const waterTemp = waterData.actualValue.toFixed(1);
const airTemp = airData.actualValue.toFixed(1);
const waterLevel = levelData.actualValue.toFixed(2);

const seoDescription = en.seo.description
	.replace('%airTemp%', airTemp)
	.replace('%waterTemp%', waterTemp);

const getPrognosisLabel = (q: number, t: any) => {
	if (q === 3) return t.prognosisExcellent;
	if (q === 2) return t.prognosisGood;
	return t.prognosisDiscouraged;
};

const prognosisLabel = getPrognosisLabel(qualityData.quality, en);

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": [
		{
			"@type": "Question",
			"name": en.faqQ1,
			"acceptedAnswer": {
				"@type": "Answer",
				"text": en.faqA1.replace('%waterTemp%', waterTemp)
			}
		},
		{
			"@type": "Question",
			"name": en.faqQ2,
			"acceptedAnswer": {
				"@type": "Answer",
				"text": en.faqA2.replace('%airTemp%', airTemp)
			}
		},
		{
			"@type": "Question",
			"name": en.faqQ3,
			"acceptedAnswer": {
				"@type": "Answer",
				"text": en.faqA3.replace('%prognosis%', prognosisLabel)
			}
		}
	]
};
---

<Layout title={en.seo.title} description={seoDescription} lang="en">
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

	<div class="space-y-4">
		<SwimPrognosis 
			quality={qualityData.quality}
			lastUpdate={qualityData.lastUpdate}
			updateLabel={en.updateLabel}
			t={en}
			data={qualityData.data}
		/>

		<MetricCard 
			id="water-chart"
			title={en.waterTemp}
			value={waterTemp}
			unit="°C"
			description={en.waterTempDesc}
			lastUpdate={waterData.lastUpdate}
			updateLabel={en.updateLabel}
			dataWeek={waterData.chart.week}
			dataMonth={waterData.chart.month}
			textWeek={en.week}
			textMonth={en.month}
			textToday={en.today}
		/>

		<MetricCard 
			id="air-chart"
			title={en.airTemp}
			value={airTemp}
			unit="°C"
			description={en.airTempDesc}
			lastUpdate={airData.lastUpdate}
			updateLabel={en.updateLabel}
			dataWeek={airData.chart.week}
			dataMonth={airData.chart.month}
			textWeek={en.week}
			textMonth={en.month}
			textToday={en.today}
		/>

		<MetricCard 
			id="level-chart"
			title={en.waterLevel}
			value={`${waterLevel > 0 ? '+' : ''}${waterLevel}`}
			unit="m"
			description={en.waterLevelDesc}
			lastUpdate={levelData.lastUpdate}
			updateLabel={en.updateLabel}
			dataWeek={levelData.chart.week}
			dataMonth={levelData.chart.month}
			textWeek={en.week}
			textMonth={en.month}
			textToday={en.today}
		/>
	</div>
</Layout>
