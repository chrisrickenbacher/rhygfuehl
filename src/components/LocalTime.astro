---
import { formatLocalTime } from '../utils/date';

interface Props {
	datetime: string | null;
	label: string;
	class?: string;
}

const { datetime, label, class: className } = Astro.props;
---

<time
	class={`local-time opacity-60 text-xs ${className || ""}`}
	datetime={datetime}
	data-label={label}
>
	{label}: --.--.--, --:--
</time>

<script>
	import { formatLocalTime } from '../utils/date';

	function updateLocalTimes() {
		const times = document.querySelectorAll('.local-time');
		const lang = document.documentElement.lang || 'de';
		
		times.forEach(timeEl => {
			const datetime = timeEl.getAttribute('datetime');
			const label = timeEl.getAttribute('data-label');
			const formatted = formatLocalTime(datetime, lang);

			if (formatted) {
				timeEl.textContent = `${label}: ${formatted}`;
			} else {
				timeEl.textContent = '';
			}
		});
	}

	// Run on initial load
	updateLocalTimes();

	// Run after view transitions
	document.addEventListener('astro:after-swap', updateLocalTimes);
</script>
