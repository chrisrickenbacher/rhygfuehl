---
interface Props {
	id: string;
	dataWeek: number[];
	dataMonth: number[];
	textWeek?: string;
	textMonth?: string;
	lastUpdate?: string;
}

const { id, dataWeek, dataMonth, textWeek = "Week", textMonth = "Month", lastUpdate } = Astro.props;
---

<div class="chart-container relative h-[250px] w-full my-4">
	<div class="flex justify-between items-center mb-4">
		<div class="flex gap-2">
			<button
				class="time-toggle px-3 py-1 text-xs rounded-full bg-gray-200 dark:bg-white/10 hover:opacity-80 transition-all"
				data-id={id}
				data-time="week"
			>
				{textWeek}
			</button>
			<button
				class="time-toggle px-3 py-1 text-xs rounded-full bg-gray-100 dark:bg-white/5 opacity-50 hover:opacity-100 transition-all"
				data-id={id}
				data-time="month"
			>
				{textMonth}
			</button>
		</div>
		{lastUpdate && <span class="text-xs opacity-60">{lastUpdate}</span>}
	</div>
	<canvas id={id}></canvas>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script define:vars={{ id, dataWeek, dataMonth }}>
	document.addEventListener('DOMContentLoaded', () => {
		const ctx = document.getElementById(id).getContext('2d');
		const isDarkMode = document.documentElement.classList.contains('dark');
		const color = isDarkMode ? '#FFFFFF' : '#002855';
		const gridColor = isDarkMode ? 'rgba(255, 255, 255, 0.1)' : 'rgba(0, 40, 85, 0.1)';

		let currentData = dataWeek;

		const config = {
			type: 'line',
			data: {
				labels: currentData.map((_, i) => i),
				datasets: [{
					data: currentData,
					borderColor: color,
					borderWidth: 4,
					tension: 0.4,
					pointRadius: 0,
					fill: false,
				}]
			},
			options: {
				responsive: true,
				maintainAspectRatio: false,
				plugins: {
					legend: { display: false },
					tooltip: { enabled: true }
				},
				scales: {
					x: { display: false },
					y: {
						ticks: { 
							color: color, 
							stepSize: 2,
							font: {
								size: 10
							}
						},
						grid: { color: gridColor }
					}
				},
				layout: {
					padding: {
						bottom: 20
					}
				},
				animation: {
					duration: 1000,
					easing: 'easeInOutQuart'
				}
			}
		};

		const chart = new Chart(ctx, config);

		// Handle switching between week/month
		const buttons = document.querySelectorAll(`.time-toggle[data-id="${id}"]`);
		buttons.forEach(btn => {
			btn.addEventListener('click', () => {
				const time = btn.getAttribute('data-time');
				const newData = time === 'week' ? dataWeek : dataMonth;
				
				// Update UI state
				buttons.forEach(b => b.classList.add('opacity-50'));
				btn.classList.remove('opacity-50');
				
				// Update Chart
				chart.data.labels = newData.map((_, i) => i);
				chart.data.datasets[0].data = newData;
				chart.update();
			});
		});
	});
</script>