---
import { pwaInfo } from 'virtual:pwa-info';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import de from '../locales/de.json';
import en from '../locales/en.json';
import '../assets/index.css';

interface Props {
	title: string;
	description: string;
	lang: string;
}

const { title, description, lang } = Astro.props;
const t = lang === 'de' ? de : en;

const canonicalURL = new URL(Astro.url.pathname, 'https://rhygfuehl.ch');
const socialImageURL = new URL('/apple-touch-icon.png', 'https://rhygfuehl.ch');
---

<!doctype html>
<html lang={lang} class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={socialImageURL} />
		<meta property="og:locale" content={lang === 'de' ? 'de_CH' : 'en_GB'} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={socialImageURL} />
		
		<!-- PWA Meta Tags -->
		<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#002855" media="(prefers-color-scheme: dark)" />
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content="rhygfuehl" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		{pwaInfo && <link rel="manifest" href={pwaInfo.webManifest.href} />}

		<!-- Umami Cloud Tracking -->
		<script defer src="https://cloud.umami.is/script.js" data-website-id="209370c3-c631-4cef-80f2-6fe9a59e45e4"></script>
	</head>
	<body class="min-h-screen bg-white dark:bg-darkblue text-darkblue dark:text-white transition-colors duration-300 antialiased">
		<header class="max-w-screen-md mx-auto px-5 pt-8 flex items-center justify-between">
			<h1 class="text-2xl font-bold">
				<a href={lang === 'de' ? '/' : '/en/'}>rhygfuehl</a>
			</h1>
			<nav>
				<div class="flex bg-darkblue/5 dark:bg-white/5 p-1 rounded-full border border-darkblue/10 dark:border-white/10">
					<a 
						href="/" 
						class={`px-4 py-1.5 text-xs font-bold rounded-full transition-all duration-300 ${lang === 'de' ? 'bg-white dark:bg-darkblue text-darkblue dark:text-white shadow-sm' : 'opacity-40 hover:opacity-100'}`}
					>
						DE
					</a>
					<a 
						href="/en/" 
						class={`px-4 py-1.5 text-xs font-bold rounded-full transition-all duration-300 ${lang === 'en' ? 'bg-white dark:bg-darkblue text-darkblue dark:text-white shadow-sm' : 'opacity-40 hover:opacity-100'}`}
					>
						EN
					</a>
				</div>
			</nav>
		</header>
		<main class="max-w-screen-md mx-auto px-5 py-8">
			<slot />
		</main>
		<Footer t={t} lang={lang} />

		<!-- PWA Update Prompt -->
		<div id="pwa-toast" class="fixed bottom-0 right-0 m-6 p-4 rounded-2xl bg-white dark:bg-darkblue border border-darkblue/10 dark:border-white/10 shadow-2xl translate-y-[200%] transition-transform duration-500 z-50 flex flex-col gap-3 min-w-[280px]" role="alert">
			<div class="flex items-center gap-3">
				<Icon name="refresh" class="w-5 h-5 text-blue-500" />
				<span class="text-sm font-bold">{lang === 'de' ? 'Neue Daten verfügbar' : 'New data available'}</span>
			</div>
			<div class="flex gap-2">
				<button id="pwa-refresh" class="flex-1 bg-darkblue dark:bg-white text-white dark:text-darkblue px-4 py-2 rounded-xl text-xs font-bold hover:opacity-90 transition-opacity">
					{lang === 'de' ? 'Aktualisieren' : 'Refresh'}
				</button>
				<button id="pwa-close" class="px-4 py-2 border border-darkblue/10 dark:border-white/10 rounded-xl text-xs font-bold opacity-50 hover:opacity-100 transition-opacity">
					{lang === 'de' ? 'Schliessen' : 'Close'}
				</button>
			</div>
		</div>

		<style is:global>
			@font-face {
				font-family: 'TikTok Sans';
				src: url('/fonts/tiktok-sans.ttf') format('truetype');
				font-weight: normal;
				font-style: normal;
				font-display: swap;
			}
			body {
				font-family: 'TikTok Sans', sans-serif;
			}
			.collapse-grid {
				display: grid;
				grid-template-rows: 0fr;
				transition: grid-template-rows 0.3s ease-out;
			}
			.collapse-grid.is-open {
				grid-template-rows: 1fr;
			}
			.collapse-inner {
				overflow: hidden;
			}
		</style>
		
		<script>
			import { Workbox } from 'workbox-window';

			const toast = document.getElementById('pwa-toast');
			const refreshBtn = document.getElementById('pwa-refresh');
			const closeBtn = document.getElementById('pwa-close');

			if ('serviceWorker' in navigator) {
				const wb = new Workbox('/sw.js');

				wb.addEventListener('waiting', () => {
					toast?.classList.remove('translate-y-[200%]');
				});

				refreshBtn?.addEventListener('click', () => {
					wb.addEventListener('controlling', () => {
						window.location.reload();
					});
					wb.messageSkipWaiting();
				});

				closeBtn?.addEventListener('click', () => toast?.classList.add('translate-y-[200%]'));

				wb.register();
			}
		</script>

		<script is:inline>
			document.addEventListener('DOMContentLoaded', () => {
				const toggles = document.querySelectorAll('.metric-toggle');
				
				toggles.forEach(toggle => {
					toggle.addEventListener('click', () => {
						const currentContent = toggle.nextElementSibling;
						const currentIcon = toggle.querySelector('.toggle-icon');
						const isOpen = currentContent.classList.contains('is-open');
						
						// Close all other cards
						if (!isOpen) {
							document.querySelectorAll('.collapse-grid.is-open').forEach(openContent => {
								if (openContent !== currentContent) {
									openContent.classList.remove('is-open');
									// Find the associated icon and reset it
									const otherToggle = openContent.previousElementSibling;
									const otherIcon = otherToggle.querySelector('.toggle-icon');
									if (otherIcon) otherIcon.classList.remove('rotate-180');
								}
							});
						}

						// Toggle current card
						if (isOpen) {
							currentContent.classList.remove('is-open');
							currentIcon.classList.remove('rotate-180');
						} else {
							currentContent.classList.add('is-open');
							currentIcon.classList.add('rotate-180');
						}
					});
				});
			});
		</script>
	</body>
</html>
